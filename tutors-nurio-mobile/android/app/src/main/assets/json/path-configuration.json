{
  "settings": {
    "screenshots_enabled": true
  },
  "rules": [
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "/auth/login.*",
        "/auth/create-account.*",
        "/auth/verify.*",
        "/signup.*"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web/modal"
      }
    },
    {
      "patterns": [
        "/orders/new.*",
        "/orders/.*/payment_summary.*",
        "/bookings/new.*",
        "/bookings/.*/review/new.*"
      ],
      "properties": {
        "context": "modal",
        "uri": "hotwire://fragment/web/modal"
      }
    },
    {
      "patterns": [
        "/dashboard/onboarding.*",
        "/dashboard/offers/new.*",
        "/dashboard/offers/.*/edit.*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web"
      }
    },
    {
      "patterns": [
        "/credits.*",
        "/bookings.*",
        "/dashboard.*",
        "/tutors.*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web"
      }
    }
  ]
}
